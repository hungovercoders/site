{
  "name": "site",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "rm -rf .astro node_modules/.astro dist && ./scripts/fetch-training-repos.sh && astro build && pagefind --site dist/client",
    "preview": "npm run build && wrangler dev",
    "astro": "astro",
    "generate-types": "wrangler types",
    "deploy": "npm run build && wrangler deploy",
    "redirects:generate": "node redirects/generate.mjs",
    "redirects:deploy": "npm run redirects:generate && wrangler deploy --config redirects/wrangler.jsonc"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.5.4",
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.3.7",
    "pagefind": "^1.5.2",
    "sharp": "^0.34.3"
  },
  "devDependencies": {
    "wrangler": "^4.94.0",
    "@axe-core/playwright": "^4.11.1",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.40.0",
    "markdownlint-cli": "^0.47.0"
  },
  "overrides": {
    "vite": "^7",
    "esbuild": "^0.28.1"
  }
}
