---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import GtmNoscript from '../../components/GtmNoscript.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 880px;
				max-width: calc(100% - 2em);
			}
			.page-header {
				text-align: center;
				margin-bottom: 3.5rem;
			}
			.page-header h1 {
				margin-bottom: 0.5rem;
			}
			.page-header p {
				color: rgb(var(--gray));
				margin: 0;
			}
			.grid {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 3rem 2rem;
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.card a {
				display: block;
				color: inherit;
				text-decoration: none;
			}
			.card-image {
				width: 100%;
				aspect-ratio: 1200 / 630;
				object-fit: cover;
				display: block;
				border-radius: 8px;
				margin-bottom: 1rem;
				transition: 0.15s ease;
			}
			.card a:hover .card-image {
				transform: translateY(-2px);
				box-shadow: var(--box-shadow);
			}
			.card .date {
				color: rgb(var(--gray));
				font-size: 0.85rem;
				margin: 0 0 0.4rem;
			}
			.card h2 {
				margin: 0 0 0.5rem;
				font-size: 1.4rem;
				line-height: 1.3;
				color: rgb(var(--black));
			}
			.card a:hover h2 {
				color: var(--accent);
			}
			.card .desc {
				color: rgb(var(--gray-dark));
				font-size: 0.95rem;
				line-height: 1.5;
				margin: 0;
			}
			@media (max-width: 720px) {
				.grid {
					grid-template-columns: 1fr;
					gap: 2.5rem;
				}
			}
		</style>
	</head>
	<body>
		<GtmNoscript />
		<Header />
		<main>
			<header class="page-header">
				<h1>Blog</h1>
				<p>{posts.length} posts &middot; opinions, walkthroughs, and the occasional hangover</p>
			</header>
			<ul class="grid">
				{
					posts.map((post) => {
						const imgPath = post.data.image?.path;
						return (
							<li class="card">
								<a href={`/blog/${post.id}/`}>
									{imgPath && <img class="card-image" src={imgPath} alt="" loading="lazy" />}
									<p class="date">
										<FormattedDate date={post.data.date} />
									</p>
									<h2>{post.data.title}</h2>
									<p class="desc">{post.data.description}</p>
								</a>
							</li>
						);
					})
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
