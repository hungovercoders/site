---
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import GtmNoscript from '../components/GtmNoscript.astro';
import Header from '../components/Header.astro';

interface Props {
	title: string;
	description: string;
	series: string;
	order: number;
	seriesLessons: CollectionEntry<'training'>[];
	currentSlug: string;
	headings: MarkdownHeading[];
}

const { title, description, series, seriesLessons, currentSlug, headings } = Astro.props;

function lessonSlug(entry: CollectionEntry<'training'>) {
	return entry.id.split('/').at(-2)!;
}

const currentIndex = seriesLessons.findIndex((l) => lessonSlug(l) === currentSlug);
const prev = currentIndex > 0 ? seriesLessons[currentIndex - 1] : null;
const next = currentIndex < seriesLessons.length - 1 ? seriesLessons[currentIndex + 1] : null;

const tocHeadings = headings.filter((h) => h.depth === 2);
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.layout {
				display: flex;
				gap: 2rem;
				max-width: 1280px;
				margin: 2rem auto;
				padding: 0 1rem;
				align-items: flex-start;
			}
			.sidebar {
				flex: 0 0 220px;
				position: sticky;
				top: 1rem;
			}
			.sidebar h3 {
				text-transform: capitalize;
				margin: 0 0 0.75rem;
				font-size: 0.85rem;
				letter-spacing: 0.05em;
				color: rgb(var(--gray));
			}
			.sidebar ol {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
				gap: 0.25rem;
			}
			.sidebar ol li a {
				display: block;
				padding: 0.35rem 0.5rem;
				border-radius: 4px;
				text-decoration: none;
				font-size: 0.9rem;
				color: rgb(var(--gray-dark));
				line-height: 1.3;
			}
			.sidebar ol li a:hover {
				color: rgb(var(--accent));
			}
			.sidebar ol li a.active {
				background: rgb(var(--accent));
				color: white;
				font-weight: 600;
			}
			.prose {
				flex: 1;
				min-width: 0;
				max-width: 720px;
			}
			.prose h1 {
				margin: 0 0 0.5rem;
			}
			.prose :global(pre) {
				overflow-x: auto;
				max-width: 100%;
				font-size: 0.85em;
			}
			.toc {
				flex: 0 0 200px;
				position: sticky;
				top: 1rem;
				max-height: calc(100vh - 2rem);
				overflow-y: auto;
			}
			.toc h3 {
				text-transform: capitalize;
				margin: 0 0 0.75rem;
				font-size: 0.85rem;
				letter-spacing: 0.05em;
				color: rgb(var(--gray));
			}
			.toc ol {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
				gap: 0.15rem;
			}
			.toc ol li a {
				display: block;
				padding: 0.35rem 0.6rem;
				border-left: 2px solid transparent;
				text-decoration: none;
				font-size: 0.85rem;
				color: rgb(var(--gray-dark));
				line-height: 1.35;
				transition:
					color 0.15s ease,
					border-left-color 0.15s ease,
					background 0.15s ease;
			}
			.toc ol li a:hover {
				color: rgb(var(--accent));
				background: rgba(35, 55, 255, 0.04);
			}
			.toc ol li a.active {
				color: rgb(var(--accent));
				font-weight: 600;
				border-left-color: rgb(var(--accent));
				background: rgba(35, 55, 255, 0.06);
			}
			.toc-mobile {
				display: none;
				margin: 0 0 1.5rem;
				padding: 0.65rem 1rem;
				background: rgb(var(--gray-light));
				border-radius: 6px;
				font-size: 0.9rem;
			}
			.toc-mobile summary {
				cursor: pointer;
				font-weight: 600;
				color: rgb(var(--gray-dark));
				list-style: none;
			}
			.toc-mobile summary::-webkit-details-marker {
				display: none;
			}
			.toc-mobile summary::before {
				content: '▸ ';
				display: inline-block;
				margin-right: 0.25rem;
				transition: transform 0.15s ease;
			}
			.toc-mobile[open] summary::before {
				transform: rotate(90deg);
			}
			.toc-mobile ol {
				list-style: none;
				margin: 0;
				padding: 0.5rem 0 0;
				display: flex;
				flex-direction: column;
				gap: 0.15rem;
			}
			.toc-mobile ol li a {
				display: block;
				padding: 0.3rem 0.5rem;
				text-decoration: none;
				color: rgb(var(--gray-dark));
				border-radius: 4px;
			}
			.toc-mobile ol li a:hover {
				color: rgb(var(--accent));
			}
			.toc-mobile ol li a.active {
				color: rgb(var(--accent));
				font-weight: 600;
			}
			.lesson-nav {
				display: flex;
				justify-content: space-between;
				margin-top: 3rem;
				padding-top: 1.5rem;
				border-top: 1px solid rgb(var(--gray-light));
				gap: 1rem;
			}
			.lesson-nav a {
				padding: 0.5rem 1rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 6px;
				text-decoration: none;
				color: rgb(var(--gray-dark));
				font-size: 0.9rem;
			}
			.lesson-nav a:hover {
				border-color: rgb(var(--accent));
				color: rgb(var(--accent));
			}
			.lesson-nav .next {
				margin-left: auto;
			}
			@media (max-width: 1100px) {
				.toc {
					display: none;
				}
				.toc-mobile {
					display: block;
				}
			}
			@media (max-width: 720px) {
				.layout {
					flex-direction: column;
				}
				.sidebar {
					position: static;
					flex: none;
					width: 100%;
				}
				.prose {
					width: 100%;
					max-width: 100%;
				}
			}
		</style>
	</head>
	<body>
		<GtmNoscript />
		<Header />
		<div class="layout">
			<nav class="sidebar">
				<h3>{series} lessons</h3>
				<ol>
					{
						seriesLessons.map((l) => (
							<li>
								<a
									href={`/training/${l.data.series}/${lessonSlug(l)}/`}
									class={lessonSlug(l) === currentSlug ? 'active' : ''}
								>
									{l.data.order}. {l.data.title}
								</a>
							</li>
						))
					}
				</ol>
			</nav>
			<article class="prose">
				<h1>{title}</h1>
				<hr />
				{
					tocHeadings.length > 0 && (
						<details class="toc-mobile">
							<summary>On this page</summary>
							<ol>
								{tocHeadings.map((h) => (
									<li>
										<a href={`#${h.slug}`} data-toc-slug={h.slug}>
											{h.text}
										</a>
									</li>
								))}
							</ol>
						</details>
					)
				}
				<slot />
				<nav class="lesson-nav">
					{
						prev && (
							<a href={`/training/${prev.data.series}/${lessonSlug(prev)}/`} class="prev">
								← {prev.data.title}
							</a>
						)
					}
					{
						next && (
							<a href={`/training/${next.data.series}/${lessonSlug(next)}/`} class="next">
								{next.data.title} →
							</a>
						)
					}
				</nav>
			</article>
			{
				tocHeadings.length > 0 && (
					<aside class="toc">
						<h3>On this page</h3>
						<ol>
							{tocHeadings.map((h) => (
								<li>
									<a href={`#${h.slug}`} data-toc-slug={h.slug}>
										{h.text}
									</a>
								</li>
							))}
						</ol>
					</aside>
				)
			}
		</div>
		<Footer />
		<script>
			// Active-section highlighting for the per-page Table of Contents.
			// Watches every h2 in the prose; the topmost one inside the
			// rootMargin band wins. Updates both the sticky sidebar and the
			// inline collapsible ToC since they share data-toc-slug values.
			const headingEls = Array.from(document.querySelectorAll<HTMLElement>('article.prose h2[id]'));
			const tocLinks = Array.from(
				document.querySelectorAll<HTMLAnchorElement>('a[data-toc-slug]')
			);
			if (headingEls.length > 0 && tocLinks.length > 0) {
				const setActive = (slug: string) => {
					tocLinks.forEach((link) => {
						link.classList.toggle('active', link.dataset.tocSlug === slug);
					});
				};
				const observer = new IntersectionObserver(
					(entries) => {
						const visible = entries
							.filter((entry) => entry.isIntersecting)
							.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
						if (visible.length > 0) {
							setActive(visible[0].target.id);
							return;
						}
						// Fallback: pick the last heading whose top is above the
						// viewport's reading band so something is always highlighted.
						const passed = headingEls.filter((h) => h.getBoundingClientRect().top < 100);
						if (passed.length > 0) {
							setActive(passed[passed.length - 1].id);
						}
					},
					{ rootMargin: '-80px 0px -70% 0px' }
				);
				headingEls.forEach((h) => observer.observe(h));
				// Initialise on load — pick whichever heading is closest to the
				// top of the viewport so something is highlighted before scroll.
				const initial = headingEls.find((h) => h.getBoundingClientRect().top >= 0);
				if (initial) setActive(initial.id);
				else if (headingEls.length > 0) setActive(headingEls[0].id);
			}
		</script>
	</body>
</html>
