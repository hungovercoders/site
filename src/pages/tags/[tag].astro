---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import GtmNoscript from '../../components/GtmNoscript.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	const grouped = new Map<string, { display: string; posts: typeof posts }>();
	for (const post of posts) {
		for (const tag of post.data.tags ?? []) {
			if (tag.toLowerCase() === 'hungovercoders') continue;
			const slug = tag.toLowerCase().replace(/\s+/g, '-');
			if (!grouped.has(slug)) grouped.set(slug, { display: tag, posts: [] });
			grouped.get(slug)!.posts.push(post);
		}
	}
	return [...grouped.entries()].map(([slug, { display, posts }]) => ({
		params: { tag: slug },
		props: {
			display,
			posts: posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
		},
	}));
}

const { display, posts } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`${display} | ${SITE_TITLE}`}
			description={`Posts tagged ${display} on hungovercoders.`}
		/>
		<style>
			main {
				width: 1100px;
				max-width: calc(100% - 2em);
			}
			.page-header {
				text-align: center;
				margin-bottom: 3rem;
			}
			.page-header .eyebrow {
				color: rgb(var(--gray));
				text-transform: uppercase;
				letter-spacing: 1.5px;
				font-size: 0.8rem;
				margin: 0 0 0.5rem;
			}
			.page-header h1 {
				margin: 0 0 0.5rem;
				text-transform: lowercase;
			}
			.page-header .count {
				color: rgb(var(--gray));
				margin: 0;
			}
			.page-header .back {
				display: inline-block;
				margin-top: 1rem;
				color: var(--accent);
				text-decoration: none;
				font-size: 0.9rem;
			}
			.page-header .back:hover {
				text-decoration: underline;
			}
			.grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
				gap: 2rem;
				list-style: none;
				padding: 0;
				margin: 0;
			}
			.card {
				display: flex;
				flex-direction: column;
				border-radius: 14px;
				overflow: hidden;
				background: white;
				border: 1px solid rgb(var(--gray-light));
				transition: 0.2s ease;
				height: 100%;
			}
			.card:hover {
				border-color: var(--accent);
				box-shadow: var(--box-shadow);
				transform: translateY(-2px);
			}
			.card a {
				display: flex;
				flex-direction: column;
				height: 100%;
				color: inherit;
				text-decoration: none;
			}
			.card-image {
				width: 100%;
				aspect-ratio: 1200 / 630;
				object-fit: cover;
				display: block;
				background: rgb(var(--gray-light));
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.card-body {
				padding: 1.25rem 1.5rem 1.5rem;
				display: flex;
				flex-direction: column;
				gap: 0.5rem;
			}
			.card .date {
				color: rgb(var(--gray));
				font-size: 0.8rem;
				text-transform: uppercase;
				letter-spacing: 0.6px;
				margin: 0;
			}
			.card h2 {
				margin: 0;
				font-size: 1.35rem;
				line-height: 1.25;
				color: rgb(var(--black));
			}
			.card:hover h2 {
				color: var(--accent);
			}
			.card .desc {
				color: rgb(var(--gray-dark));
				font-size: 0.95rem;
				line-height: 1.45;
				margin: 0;
			}
			@media (max-width: 720px) {
				.grid {
					grid-template-columns: 1fr;
					gap: 1.25rem;
				}
			}
		</style>
	</head>
	<body>
		<GtmNoscript />
		<Header />
		<main>
			<header class="page-header">
				<p class="eyebrow">Tag</p>
				<h1>#{display}</h1>
				<p class="count">{posts.length} {posts.length === 1 ? 'post' : 'posts'}</p>
				<a class="back" href="/tags/">&larr; all tags</a>
			</header>
			<ul class="grid">
				{
					posts.map((post) => {
						const imgPath = post.data.image?.path;
						return (
							<li class="card">
								<a href={`/blog/${post.id}/`}>
									{imgPath && <img class="card-image" src={imgPath} alt="" loading="lazy" />}
									<div class="card-body">
										<p class="date">
											<FormattedDate date={post.data.date} />
										</p>
										<h2>{post.data.title}</h2>
										<p class="desc">{post.data.description}</p>
									</div>
								</a>
							</li>
						);
					})
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
