---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Search from '../components/Search.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Lost? · ${SITE_TITLE}`} description="That page has wandered off. Try a search or one of these instead." />
		<style>
			main {
				width: 760px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: var(--space-7) 1em var(--space-7);
				text-align: center;
			}
			.code {
				font-family: var(--font-display);
				font-size: 6rem;
				line-height: 1;
				color: var(--accent);
				margin: 0;
				letter-spacing: -0.02em;
			}
			.hed {
				font-size: 1.6rem;
				margin: var(--space-4) 0 var(--space-2);
				color: rgb(var(--black));
			}
			.copy {
				color: rgb(var(--gray-dark));
				margin: 0 auto var(--space-6);
				max-width: 520px;
				line-height: 1.6;
			}
			.search-wrap {
				display: flex;
				justify-content: center;
				margin: 0 auto var(--space-6);
			}
			.search-wrap :global(#search) {
				width: 360px;
				max-width: 100%;
			}
			.grid {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: var(--space-4);
				text-align: left;
			}
			.card {
				display: block;
				padding: var(--space-5);
				border: 1px solid rgb(var(--gray-light));
				border-radius: 10px;
				background: rgb(var(--surface));
				color: rgb(var(--gray-dark));
				text-decoration: none;
				transition: border-color 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
			}
			.card:hover {
				border-color: var(--accent);
				transform: translateY(-2px);
				box-shadow: 0 8px 20px rgba(var(--gray), 0.15);
				text-decoration: none;
			}
			.card h3 {
				margin: 0 0 0.25rem;
				color: rgb(var(--black));
				font-size: 1.1rem;
			}
			.card p {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}
			@media (max-width: 720px) {
				.code {
					font-size: 4.5rem;
				}
				.grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main id="main-content">
			<p class="code">404</p>
			<h1 class="hed">Page's gone walkabout</h1>
			<p class="copy">
				That URL doesn't ring a bell. Probably renamed, possibly never existed, definitely not here now.
				Try a search or one of the doors below.
			</p>
			<div class="search-wrap"><Search /></div>
			<div class="grid">
				<a class="card" href="/blog">
					<h3>Blog →</h3>
					<p>Walkthroughs, opinions, and the occasional hangover.</p>
				</a>
				<a class="card" href="/training">
					<h3>Training →</h3>
					<p>Hands-on lesson series built end-to-end.</p>
				</a>
				<a class="card" href="/projects">
					<h3>Projects →</h3>
					<p>Live apps, work-in-progress, archived experiments.</p>
				</a>
				<a class="card" href="/tags">
					<h3>Tags →</h3>
					<p>Browse by topic — find the one that scratches the itch.</p>
				</a>
			</div>
		</main>
		<Footer />
	</body>
</html>
