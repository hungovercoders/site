---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import GtmNoscript from '../components/GtmNoscript.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { excerpt } from '../utils/excerpt';

const latest = (await getCollection('blog'))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 760px;
				max-width: calc(100% - 2em);
			}
			.hero {
				display: flex;
				align-items: center;
				gap: 2rem;
				padding: 2.5rem 0 1rem;
				border-bottom: 1px solid rgb(var(--gray-light));
				margin-bottom: 2.5rem;
			}
			.hero-mark {
				flex: 0 0 auto;
				width: 140px;
				height: 140px;
				display: block;
				filter: drop-shadow(0 8px 24px rgba(35, 55, 255, 0.15));
			}
			.hero-text h1 {
				margin: 0 0 0.5rem;
				line-height: 1;
			}
			.hero-text .tagline {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 1.05rem;
				line-height: 1.5;
			}
			.intro p {
				font-size: 1.05rem;
				line-height: 1.65;
			}
			.intro strong {
				color: rgb(var(--black));
			}
			.latest {
				margin-top: 3.5rem;
				padding-top: 2rem;
				border-top: 1px solid rgb(var(--gray-light));
			}
			.latest-header {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				margin-bottom: 1.5rem;
			}
			.latest-header h2 {
				margin: 0;
				font-size: 1.5rem;
			}
			.latest-header a {
				color: var(--accent);
				text-decoration: none;
				font-size: 0.9rem;
			}
			.latest-header a:hover {
				text-decoration: underline;
			}
			.latest-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-direction: column;
			}
			.latest-list li {
				border-top: 1px solid rgb(var(--gray-light));
				padding: 1.5rem 0;
			}
			.latest-list li:last-child {
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.latest-list a {
				display: block;
				color: inherit;
				text-decoration: none;
			}
			.latest-list .date {
				color: rgb(var(--gray));
				font-size: 0.78rem;
				text-transform: uppercase;
				letter-spacing: 1px;
				margin: 0 0 0.35rem;
			}
			.latest-list h3 {
				margin: 0 0 0.4rem;
				font-size: 1.25rem;
				line-height: 1.3;
				color: rgb(var(--black));
				transition: color 0.15s ease;
			}
			.latest-list a:hover h3 {
				color: var(--accent);
			}
			.latest-list .desc {
				color: rgb(var(--gray-dark));
				font-size: 0.95rem;
				line-height: 1.5;
				margin: 0;
			}
			@media (max-width: 720px) {
				.hero {
					flex-direction: column;
					text-align: center;
					gap: 1.25rem;
				}
				.hero-mark {
					width: 100px;
					height: 100px;
				}
			}
		</style>
	</head>
	<body>
		<GtmNoscript />
		<Header />
		<main id="main-content">
			<section class="hero">
				<img class="hero-mark" src="/icon-512.png" alt="" width="140" height="140" />
				<div class="hero-text">
					<h1>hungovercoders</h1>
					<p class="tagline">
						Folk tales of working in tech from the South Wales valleys. Built with the AI on the
						team and the dog on the sofa.
					</p>
				</div>
			</section>

			<section class="intro">
				<p>
					I wanted a single place on the internet that was mine. Source-controlled, cheap to run,
					honest about how it works. The kind of tech blog you'd write if you didn't have to
					impress anyone. Just help a fellow hungovercoder get something working before the next
					round.
				</p>
				<p>
					The posts are walkthroughs of things I actually built: data pipelines, cloud
					infrastructure, APIs, DevOps tooling, and these days a lot of working alongside AI agents.
					Not theoretical. Not sanitised. Some written on a Friday night, most polished on a Sunday
					morning with the dog asleep on the sofa. The code ran on my laptop first.
				</p>
				<p>
					The worldview, if you want it in one sentence: <strong>small, cheap, and yours beats big,
					fancy, and rented.</strong> If one slightly hungover person can't deploy it on a Tuesday,
					or a Saturday morning with a head on them, it's too complicated.
				</p>
				<p>
					AI is on the team now. Claude Code (and friends) does the typing; I do the judgement. The
					blog is what comes out the other side: what I built, what I rewrote, what I'd do
					differently. The opinion's still mine.
				</p>
			</section>

			<section class="latest">
				<div class="latest-header">
					<h2>Latest from the blog</h2>
					<a href="/blog">All posts &rarr;</a>
				</div>
				<ul class="latest-list">
					{
						latest.map((post) => {
							const blurb = excerpt(post.body, 180) || post.data.description;
							return (
								<li>
									<a href={`/blog/${post.id}/`}>
										<p class="date">
											<FormattedDate date={post.data.date} />
										</p>
										<h3>{post.data.title}</h3>
										<p class="desc">{blurb}</p>
									</a>
								</li>
							);
						})
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
