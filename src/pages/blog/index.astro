---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import GtmNoscript from '../../components/GtmNoscript.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { excerpt } from '../../utils/excerpt';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 880px;
				max-width: calc(100% - 2em);
			}
			.page-header {
				text-align: center;
				margin-bottom: 3.5rem;
			}
			.page-header h1 {
				margin-bottom: 0.5rem;
			}
			.page-header p {
				color: rgb(var(--gray));
				margin: 0;
			}
			.posts {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-direction: column;
			}
			.post {
				border-top: 1px solid rgb(var(--gray-light));
				padding: 2rem 0;
			}
			.post:last-child {
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.post a {
				display: block;
				color: inherit;
				text-decoration: none;
			}
			.post .date {
				color: rgb(var(--gray));
				font-size: 0.8rem;
				text-transform: uppercase;
				letter-spacing: 1px;
				margin: 0 0 0.5rem;
			}
			.post h2 {
				margin: 0 0 0.5rem;
				font-size: 1.7rem;
				line-height: 1.25;
				color: rgb(var(--black));
				transition: color 0.15s ease;
			}
			.post a:hover h2 {
				color: var(--accent);
			}
			.post .desc {
				color: rgb(var(--gray-dark));
				font-size: 1rem;
				line-height: 1.55;
				margin: 0;
			}
			.post .tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4rem;
				margin-top: 0.85rem;
			}
			.post .tag {
				font-size: 0.7rem;
				text-transform: uppercase;
				letter-spacing: 0.6px;
				padding: 0.2rem 0.6rem;
				color: rgb(var(--gray));
				border: 1px solid rgb(var(--gray-light));
				border-radius: 999px;
			}
			@media (max-width: 720px) {
				.post {
					padding: 1.5rem 0;
				}
				.post h2 {
					font-size: 1.4rem;
				}
			}
		</style>
	</head>
	<body>
		<GtmNoscript />
		<Header />
		<main id="main-content">
			<header class="page-header">
				<h1>Blog</h1>
				<p>{posts.length} posts &middot; opinions, walkthroughs, and the occasional hangover</p>
			</header>
			<ul class="posts">
				{
					posts.map((post) => {
						const tags = (post.data.tags ?? []).filter(
							(t) => t.toLowerCase() !== 'hungovercoders',
						);
						const blurb = excerpt(post.body, 220) || post.data.description;
						return (
							<li class="post">
								<a href={`/blog/${post.id}/`}>
									<p class="date">
										<FormattedDate date={post.data.date} />
									</p>
									<h2>{post.data.title}</h2>
									<p class="desc">{blurb}</p>
									{tags.length > 0 && (
										<div class="tags">
											{tags.slice(0, 4).map((t) => (
												<span class="tag">{t}</span>
											))}
										</div>
									)}
								</a>
							</li>
						);
					})
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
